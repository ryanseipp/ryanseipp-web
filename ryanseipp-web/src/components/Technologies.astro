---
import AzureIcon from "./icons/AzureIcon.astro";
import CSharpIcon from "./icons/CSharpIcon.astro";
import DockerIcon from "./icons/DockerIcon.astro";
import GitIcon from "./icons/GitIcon.astro";
import GoIcon from "./icons/GoIcon.astro";
import KubernetesIcon from "./icons/KubernetesIcon.astro";
import LinuxIcon from "./icons/LinuxIcon.astro";
import PostgresIcon from "./icons/PostgresIcon.astro";
import ReactIcon from "./icons/ReactIcon.astro";
import RustIcon from "./icons/RustIcon.astro";
import SqlServerIcon from "./icons/SqlServerIcon.astro";
import TypescriptIcon from "./icons/TypescriptIcon.astro";

type Props = {
  class?: astroHTML.JSX.HTMLAttributes["class"];
};

const props = Astro.props;

const icons = [
  {Icon: RustIcon, name: "Rust"},
  {Icon: CSharpIcon, name: "C#"},
  {Icon: GoIcon, name: "Go"},
  {Icon: TypescriptIcon, name: "Typescript"},
  {Icon: ReactIcon, name: "React"},
  {Icon: KubernetesIcon, name: "Kubernetes"},
  {Icon: DockerIcon, name: "Docker"},
  {Icon: AzureIcon, name: "Azure"},
  {Icon: PostgresIcon, name: "PostgreSQL"},
  {Icon: SqlServerIcon, name: "SQL Server"},
  {Icon: GitIcon, name: "Git"},
  {Icon: LinuxIcon, name: "Linux"},
];
---

<section class={props.class}>
  <h2 class="mb-4 text-xl">Technologies</h2>
  <ul class="mx-auto flex flex-wrap justify-center gap-x-2 gap-y-6">
    {
      icons.map(({Icon, name}) => (
        <li class="flex w-24 flex-col items-center gap-2">
          <Icon size="4rem" />
          <span>{name}</span>
        </li>
      ))
    }
  </ul>
</section>
