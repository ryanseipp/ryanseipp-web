---
import TextLink from "./TextLink.astro";
import IconLink from "./IconLink.astro";
import ThemeToggle from "./ThemeToggle.astro";
---

<header>
  <nav
    class="mb-4 flex flex-col items-center gap-6 px-16 py-8 sm:flex-row sm:px-0"
    transition:name="navigation"
    transition:animate="initial"
  >
    <ul
      class="flex flex-1 items-center justify-center gap-8 text-xl sm:justify-start"
    >
      <li>
        <TextLink href="/">Home</TextLink>
      </li>
      <li>
        <TextLink href="/about">About</TextLink>
      </li>
    </ul>
    <ul class="flex justify-center gap-1 text-xs sm:justify-end">
      <li>
        <IconLink
          id="x-link"
          href="https://twitter.com/ryan_seipp"
          title="Follow me on X"
        >
          <svg
            width="1.25rem"
            height="1.25rem"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 1200 1227"
            role="img"
            aria-hidden="true"
            focusable="false"
          >
            <path
              d="M714.163 519.284L1160.89 0H1055.03L667.137 450.887L357.328 0H0L468.492 681.821L0 1226.37H105.866L515.491 750.218L842.672 1226.37H1200L714.137 519.284H714.163ZM569.165 687.828L521.697 619.934L144.011 79.6944H306.615L611.412 515.685L658.88 583.579L1055.08 1150.3H892.476L569.165 687.854V687.828Z"
              fill="currentColor"></path>
          </svg>
        </IconLink>
      </li>
      <li>
        <IconLink
          id="github-link"
          href="https://github.com/ryanseipp"
          title="See my projects on GitHub"
        >
          <svg
            width="1.25rem"
            height="1.25rem"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 16 16"
            role="img"
            aria-hidden="true"
            focusable="false"
          >
            <path
              fill="currentColor"
              d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38c0-.27.01-1.13.01-2.2c0-.75-.25-1.23-.54-1.48c1.78-.2 3.65-.88 3.65-3.95c0-.88-.31-1.59-.82-2.15c.08-.2.36-1.02-.08-2.12c0 0-.67-.22-2.2.82c-.64-.18-1.32-.27-2-.27c-.68 0-1.36.09-2 .27c-1.53-1.03-2.2-.82-2.2-.82c-.44 1.1-.16 1.92-.08 2.12c-.51.56-.82 1.28-.82 2.15c0 3.06 1.86 3.75 3.64 3.95c-.23.2-.44.55-.51 1.07c-.46.21-1.61.55-2.33-.66c-.15-.24-.6-.83-1.23-.82c-.67.01-.27.38.01.53c.34.19.73.9.82 1.13c.16.45.68 1.31 2.69.94c0 .67.01 1.3.01 1.49c0 .21-.15.45-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z"
            ></path>
          </svg>
        </IconLink>
      </li>
      <li>
        <IconLink
          id="linkedin-link"
          href="https://www.linkedin.com/in/seippryan"
          title="See my work experience on LinkedIn"
        >
          <svg
            width="1.25rem"
            height="1.25rem"
            xmlns="http://www.w3.org/2000/svg"
            role="img"
            aria-hidden="true"
            focusable="false"
            viewBox="0 0 128 128"
            ><path
              fill="currentColor"
              d="M116 3H12a8.91 8.91 0 0 0-9 8.8v104.42a8.91 8.91 0 0 0 9 8.78h104a8.93 8.93 0 0 0 9-8.81V11.77A8.93 8.93 0 0 0 116 3zM39.17 107H21.06V48.73h18.11zm-9-66.21a10.5 10.5 0 1 1 10.49-10.5a10.5 10.5 0 0 1-10.54 10.48zM107 107H88.89V78.65c0-6.75-.12-15.44-9.41-15.44s-10.87 7.36-10.87 15V107H50.53V48.73h17.36v8h.24c2.42-4.58 8.32-9.41 17.13-9.41C103.6 47.28 107 59.35 107 75z"
            ></path></svg
          >
        </IconLink>
      </li>
      <li>
        <IconLink
          id="rss-link"
          href="/rss.xml"
          title="Follow via RSS Feed"
          rel="alternate"
          type="application/xml"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="1.25rem"
            height="1.25rem"
            viewBox="0 0 24 24"
            role="img"
            aria-hidden="true"
            focusable="false"
          >
            <path
              fill="currentColor"
              d="M3.5 3.25a.75.75 0 0 1 .75-.75C14.053 2.5 22 10.447 22 20.25a.75.75 0 0 1-1.5 0C20.5 11.275 13.225 4 4.25 4a.75.75 0 0 1-.75-.75Zm.75 6.25C10.187 9.5 15 14.313 15 20.25a.75.75 0 0 1-1.5 0A9.25 9.25 0 0 0 4.25 11a.75.75 0 0 1 0-1.5ZM3.5 19a2 2 0 1 1 3.999-.001A2 2 0 0 1 3.5 19Z"
            ></path>
          </svg>
        </IconLink>
      </li>
      <li>
        <ThemeToggle />
      </li>
    </ul>
  </nav>
</header>
